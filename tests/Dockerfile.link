FROM alpine:3.21 AS builder
RUN apk add --no-cache build-base openssl-dev zlib-dev linux-headers git
WORKDIR /src
COPY . .
RUN make clean && make -j$(nproc)

FROM alpine:3.21
RUN apk add --no-cache python3 py3-pip py3-pillow zbar
RUN pip install --break-system-packages pyzbar
COPY --from=builder /src/objs/bin/teleproxy /usr/local/bin/teleproxy
WORKDIR /app
COPY tests/test_link.py .
CMD ["python3", "test_link.py"]
